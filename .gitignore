# Compiled binary
/local-review

# SQLite database (created next to the binary at runtime)
*.db
*.db-shm
*.db-wal

# Node dependencies
web/node_modules/

# TypeScript incremental build cache
web/tsconfig.tsbuildinfo

# Built frontend — regenerated by `npm run build`.
# The .gitkeep placeholder keeps the directory present so the Go `embed`
# directive still compiles on a fresh clone before the frontend is built.
web/dist/*
!web/dist/.gitkeep

# Logs
*.log

# OS / editor cruft
.DS_Store
.idea/
*.swp
